# Set the provider you want to use
LLM_PROVIDER=gemini

# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Get from https://console.anthropic.com (free $5 credit on signup)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional: hard budget cap in USD per run (default 0.50)
RUN_BUDGET_USD=0.50
